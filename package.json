{
  "name": "webcam-biometrics",
  "version": "0.1.1",
  "description": "Real-time webcam biometrics: face landmarks, gaze tracking, and heart rate estimation",
  "author": "Max <max_lovell@hotmail.co.uk>",
  "homepage": "https://max-lovell.github.io/WebcamBiometrics/",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/webcam-biometrics.cjs",
  "module": "./dist/webcam-biometrics.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/webcam-biometrics.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/webcam-biometrics.cjs"
      }
    },
    "./worker": {
      "default": "./dist/worker.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/webcam-biometrics.*",
    "!dist/webcam-biometrics.*.map",
    "dist/worker.js",
    "dist/types",
    "models"
  ],
  "keywords": [
    "webcam",
    "biometrics",
    "gaze-tracking",
    "eye-tracking",
    "heart-rate",
    "rppg",
    "mediapipe",
    "face-landmarks",
    "jspsych",
    "psychopy"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Max-Lovell/WebcamBiometrics.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json && cp dist/types/index.d.ts dist/types/index.d.cts",
    "build:demo": "vite build --mode demo",
    "build:check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "postpublish": "curl -sf https://cdn.jsdelivr.net/npm/webcam-biometrics@$npm_package_version/models/blazegaze/model.json > /dev/null && echo 'jsDelivr cache warmed' || echo 'Cache warm failed (non-critical)'"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "canvas": "^3.2.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@tensorflow/tfjs": "^4.22.0",
    "ml-matrix": "^6.12.1"
  }
}
